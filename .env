# Google OAuth (device flow)
GOOGLE_OAUTH_CLIENT_ID=
ALLOWED_GOOGLE_HD=your-company.com
GOOGLE_OAUTH_SCOPE=openid email profile
GOOGLE_TOKEN_POLL_TIMEOUT_SECONDS=600

# LiteLLM
LITELLM_BASE_URL=https://litellm.athena.tools

# Recommended secure mode: users call a broker that holds the LiteLLM master key
KEY_BROKER_URL=

# Direct admin mode only (do NOT distribute to end users)
LITELLM_MASTER_KEY=

# Key generation defaults (JSON array)
LITELLM_MODELS_JSON=["claude-opus-4-6","claude-sonnet-4-6","claude-haiku-4-5"]
KEY_DURATION=30d
KEY_MAX_BUDGET=
KEY_ALIAS_PREFIX=org-access
